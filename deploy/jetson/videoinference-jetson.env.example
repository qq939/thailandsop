# Copy this file to:
#   /etc/videoinference/videoinference-jetson-<instance>.env
#
# Example:
#   sudo cp videoinference-jetson.env.example /etc/videoinference/videoinference-jetson-camera0.env

CAMERA_CONFIG=/opt/videoinference/camera0/camera_config.json
CAMERA_ID=
CAMERA_INDEX=0
CAMERA_SOURCE=
OPENCV_BACKEND=

MODEL_ROOT=/opt/videoinference/camera0/DL
MODEL_ID=

RECORD_ROOT=/data/videoinference
LOG_DIR=/opt/videoinference/camera0/logs

ORT_NATIVE=/opt/onnxruntime/libonnxruntime.so
ORT_PROVIDERS=tensorrt,cuda,cpu
ORT_DEVICE_ID=0

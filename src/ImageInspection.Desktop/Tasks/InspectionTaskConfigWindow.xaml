<Window x:Class="VideoInferenceDemo.ImageInspection.Tasks.InspectionTaskConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Task Configuration"
        Width="1120"
        Height="760"
        MinWidth="1000"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8E1EA" />
        <SolidColorBrush x:Key="PanelTitleBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelSubtleTextBrush" Color="#667085" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type TextBox}}" TargetType="{x:Type TextBox}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type ComboBox}}" TargetType="{x:Type ComboBox}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type CheckBox}}" TargetType="{x:Type CheckBox}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type GroupBox}}" TargetType="{x:Type GroupBox}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="{x:Type Button}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="ConfigCardStyle" TargetType="{x:Type materialDesign:Card}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="UniformCornerRadius" Value="16" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource PanelSubtleTextBrush}" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PanelTitleBrush}" />
        </Style>

        <Style x:Key="HintTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{StaticResource PanelSubtleTextBrush}" />
        </Style>

        <Style x:Key="ListPrimaryTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PanelTitleBrush}" />
        </Style>

        <Style x:Key="ListSecondaryTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource PanelSubtleTextBrush}" />
        </Style>

        <Style x:Key="InlineIconButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
        </Style>

        <Style x:Key="LeftListPaneStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Background" Value="#F6F9FC" />
            <Setter Property="BorderBrush" Value="#E1E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="CardListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>

        <Style x:Key="CardListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="MinHeight" Value="76" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#DCE4ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="SelectionChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SelectionChrome" Property="Background" Value="#E8F3FE" />
                                <Setter TargetName="SelectionChrome" Property="BorderBrush" Value="#0F5A91" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VerticalDividerStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="1" />
            <Setter Property="Margin" Value="8,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource PanelBorderBrush}" />
        </Style>

        <Style x:Key="AddListCardButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="#E8F3FE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#0F5A91" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="RootBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="17"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#D4E6F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactOutlineButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <!-- TabControl styles -->
        <Style x:Key="TabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="TabStripPlacement" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="#EEF3F8"
                                    BorderBrush="#D8E1EA"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,0">
                                <TabPanel x:Name="HeaderPanel"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1" />
                            </Border>
                            <Border Grid.Row="1"
                                    Background="White"
                                    BorderBrush="#D8E1EA"
                                    BorderThickness="1,0,1,1"
                                    CornerRadius="0,0,12,12"
                                    Padding="16"
                                    KeyboardNavigation.TabIndex="2">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="FontFamily" Value="Microsoft YaHei" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="Padding" Value="20,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="TabText"
                                       Text="{TemplateBinding Header}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                <Setter TargetName="TabText" Property="FontWeight" Value="Bold" />
                                <Setter TargetName="TabText" Property="Foreground" Value="#0F5A91" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#E8F3FE" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="AddDefinitionItemTemplate">
            <Button Command="{Binding DataContext.AddDefinitionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource AddListCardButtonStyle}"
                    ToolTip="Add definition">
                <materialDesign:PackIcon Width="18" Height="18" Foreground="#0F5A91" Kind="Plus" />
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="AddInstanceItemTemplate">
            <Button Command="{Binding DataContext.AddInstanceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource AddListCardButtonStyle}"
                    ToolTip="Add instance">
                <materialDesign:PackIcon Width="18" Height="18" Foreground="#0F5A91" Kind="Plus" />
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="AddModelItemTemplate">
            <Button Command="{Binding DataContext.RefreshModelsFromDlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Style="{StaticResource AddListCardButtonStyle}"
                    ToolTip="Refresh DL models">
                <materialDesign:PackIcon Width="18" Height="18" Foreground="#0F5A91" Kind="Refresh" />
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0"
                    Style="{StaticResource TabControlStyle}">

            <!-- ========== 婵犵數濮烽弫鍛婃叏閻戣棄鏋侀柟闂寸绾剧粯绻涢幋娆忕労闁轰礁顑嗛妵鍕箻鐠虹儤鐎鹃梺鍛婄懃缁绘劘鐏冮梺鎸庣箓閹冲酣寮搁妶澶嬬厸濞达絽澹婇崕鎴︽煙閹绘帗鍟為柟顖涙婵℃悂濡疯閺変粙姊绘笟鈧褑澧濋梺鍝勬噺缁挸鐣烽幋锕€绀嬫い鏍ㄧ☉娴犫晛鈹戦悙鏉戠仸鐎圭顭峰畷鎴﹀箻鐠囪尙顦ч梺鍛婁緱閸欏骸螞濠婂牊鈷掑ù锝堟閸氬綊鏌涢悩鍐插闁诡喚鍏樻俊鐤槷闁稿鎸搁～婵嬫偂鎼淬垻褰庨梻浣筋嚃閸ｎ垳鎹㈠┑瀣ㄢ偓浣糕槈濮楀棛鍙嗛梺鍛婁緱閸ㄧ晫妲?Tab ========== -->
            <TabItem Header="任务定义" Style="{StaticResource TabItemStyle}">
                <materialDesign:Card Style="{StaticResource ConfigCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource LeftListPaneStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ListBox Grid.Row="0"
                                         ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                         ItemsSource="{Binding Definitions}"
                                         SelectedItem="{Binding SelectedDefinition}"
                                         Style="{StaticResource CardListBoxStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14" Background="Transparent" CornerRadius="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource ListPrimaryTextStyle}" Text="{Binding Name}" />
                                <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="Action defines the inspection execution logic." />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveDefinitionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource InlineIconButtonStyle}"
                                                            ToolTip="Remove definition">
                                                        <materialDesign:PackIcon Width="15" Height="15" Foreground="#B42318" Kind="DeleteOutline" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <ContentControl Grid.Row="1"
                                                Margin="0,6,0,0"
                                                ContentTemplate="{StaticResource AddDefinitionItemTemplate}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource VerticalDividerStyle}" />

                        <Grid Grid.Column="2" DataContext="{Binding SelectedDefinition}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="14" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="Task Definition Details" />
                                <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="Action defines the inspection execution logic." />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="104" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Enabled" />
                                <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" />

                                <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Name" />
                                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Action" />
                                <ComboBox Grid.Row="2"
                                          Grid.Column="1"
                                          Margin="0,12,0,0"
                                          IsEnabled="{Binding DataContext.HasMultipleActionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                          ItemsSource="{Binding DataContext.ActionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding ActionType, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3" Margin="0,12,0,0" VerticalAlignment="Top" Style="{StaticResource FieldLabelStyle}" Text="Description" />
                                <TextBox Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="0,12,0,0"
                                         MinHeight="88"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap" />
                            </Grid>
                        </Grid>
                    </Grid>
                </materialDesign:Card>
            </TabItem>

            <!-- ========== 婵犵數濮烽弫鍛婃叏閻戣棄鏋侀柟闂寸绾剧粯绻涢幋娆忕労闁轰礁顑嗛妵鍕箻鐠虹儤鐎鹃梺鍛婄懃缁绘劘鐏冮梺鎸庣箓閹冲酣寮搁妶澶嬬厸濞达絽澹婇崕鎴︽煙閹绘帗鍟為柟顖涙婵℃悂濡疯閺変粙姊绘笟鈧褑澧濋梺鍝勬噺缁挸鐣烽幋锕€绀嬫い鏍ㄧ☉娴犫晛鈹戦悙鏉戠仸鐎圭顭峰畷鎴﹀箻鐠囪尙顦ч梺鍛婁緱閸欏骸螞濠婂牊鈷掗柛灞剧懅缁愭梹绻涢懝鏉垮惞闁逞屽墴濞佳囨儗閸屾氨鏆﹂柕蹇嬪€曠粈鍌炴煠濞村娅撴繛鏉戝濮婃椽宕烽鐐插濠殿喖锕ㄥ畷鍨珶?Tab ========== -->
            <TabItem Header="任务实例" Style="{StaticResource TabItemStyle}">
                <materialDesign:Card Style="{StaticResource ConfigCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource LeftListPaneStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ListBox Grid.Row="0"
                                         ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                         ItemsSource="{Binding Instances}"
                                         SelectedItem="{Binding SelectedInstance}"
                                         Style="{StaticResource CardListBoxStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14" Background="Transparent" CornerRadius="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource ListPrimaryTextStyle}" Text="{Binding Name}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveInstanceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource InlineIconButtonStyle}"
                                                            ToolTip="Remove instance">
                                                        <materialDesign:PackIcon Width="15" Height="15" Foreground="#B42318" Kind="DeleteOutline" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <ContentControl Grid.Row="1"
                                                Margin="0,6,0,0"
                                                ContentTemplate="{StaticResource AddInstanceItemTemplate}" />
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource VerticalDividerStyle}" />

                        <ScrollViewer Grid.Column="2" DataContext="{Binding SelectedInstance}" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="Task Instance Details" />
                                <TextBlock Margin="0,4,0,0" Style="{StaticResource HintTextStyle}" Text="Select a task definition and bind cameras for this instance." />

                                <Grid Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Enabled" />
                                    <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" />

                                    <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Name" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Station" />
                                    <ComboBox Grid.Row="2"
                                              Grid.Column="1"
                                              Margin="0,12,0,0"
                                              DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding DataContext.Definitions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedValue="{Binding DefinitionId, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Id" />

                                    <TextBlock Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Definition" />
                                    <ComboBox Grid.Row="3"
                                              Grid.Column="1"
                                              Margin="0,12,0,0"
                                              DisplayMemberPath="DisplayName"
                                              ItemsSource="{Binding DataContext.TaskTriggerModes, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedValue="{Binding TriggerMode, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Mode" />
                                    <TextBlock Grid.Row="4"
                                               Grid.Column="1"
                                               Margin="0,8,0,0"
                                               Foreground="#B45309"
                                               Text="{Binding TriggerModeHint}"
                                               TextWrapping="Wrap" />
                                </Grid>

                                <TextBlock Margin="0,20,0,8" Style="{StaticResource SectionCaptionStyle}" Text="Cameras" />
                                <ItemsControl ItemsSource="{Binding CameraBindings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Margin="0,0,0,8" IsChecked="{Binding IsSelected}">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                                    <TextBlock Foreground="{StaticResource PanelSubtleTextBrush}" Text="{Binding SourceDescription}" />
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </materialDesign:Card>
            </TabItem>

            <!-- ========== 濠电姷鏁告慨鐑藉极閸涘﹥鍙忛柣鎴濐潟閳ь剙鍊块幐濠冪珶閳哄绉€规洏鍔戝鍫曞箣濠靛牃鍋撻鐑嗘富闁靛牆鎳愮粻浼存煟濡も偓濡繈骞冮悙鍝勫瀭妞ゆ劗濮崇花濠氭⒑閻熺増鎯堟俊顐ｎ殕缁傚秹宕滆绾惧ジ鏌涢幘妤€妫欓妤呮⒑閸涘﹦鎳冮柛鐔告綑閻ｅ嘲煤椤忓嫮鍔﹀銈嗗笂闂勫秵绂嶅鍫熺厵闁绘垶锚閻忋儵鏌嶈閸撴岸骞冮崒姘辨殾闁靛繈鍊曠粻缁樸亜閺冨倹娅曢柛妯绘倐閺岋綀绠涢弴鐐版勃闂佸搫顑堥褔顢欒箛娑樜ㄩ柨鏃囨〃缁ㄥ姊洪悷鏉库挃闁稿鍔戝畷鎴﹀閳垛晛浜鹃悷娆忓缁€鈧梺缁樼墪閵堢鐣峰ú顏呮櫢闁绘灏欓敍婊冣攽閻樻瑥瀚崝銈吤?Tab ========== -->
            <TabItem Header="模型" Style="{StaticResource TabItemStyle}">
                <materialDesign:Card Style="{StaticResource ConfigCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="310" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource LeftListPaneStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <ListBox Grid.Row="0"
                                         ItemContainerStyle="{StaticResource CardListBoxItemStyle}"
                                         ItemsSource="{Binding Models}"
                                         SelectedItem="{Binding SelectedModel}"
                                         Style="{StaticResource CardListBoxStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14" Background="Transparent" CornerRadius="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Style="{StaticResource ListPrimaryTextStyle}" Text="{Binding DisplayName}" />
                                                        <TextBlock Style="{StaticResource ListSecondaryTextStyle}" Text="{Binding SecondaryText}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DataContext.RemoveModelCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource InlineIconButtonStyle}"
                                                            ToolTip="Remove model">
                                                        <materialDesign:PackIcon Width="15" Height="15" Foreground="#B42318" Kind="DeleteOutline" />
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Button Grid.Row="1"
                                        Margin="8,10,8,0"
                                        Command="{Binding RefreshModelsFromDlCommand}"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource InlineIconButtonStyle}"
                                        ToolTip="刷新 DL 模型">
                                    <materialDesign:PackIcon Width="18"
                                                             Height="18"
                                                             Foreground="#0F5A91"
                                                             Kind="Refresh" />
                                </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource VerticalDividerStyle}" />

                        <ScrollViewer Grid.Column="2" DataContext="{Binding SelectedModel}" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="Model Details" />

                                <GroupBox Margin="0,14,0,0" Header="Basic Info">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="104" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Enabled" />
                                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" />

                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldLabelStyle}" Text="Task Type" />
                                        <TextBlock Grid.Column="4" Text="{Binding TaskType}" />

                                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Name" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Grid.ColumnSpan="4"
                                                 Margin="0,12,0,0"
                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Device Policy" />
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Grid.ColumnSpan="4"
                                                   Margin="0,12,0,0"
                                                   Foreground="{StaticResource PanelSubtleTextBrush}"
                                                   Text="{Binding DevicePolicyText}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Margin="0,12,0,0" Header="Runtime Diagnostics">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Width="88"
                                                    Command="{Binding DataContext.CheckModelEnvironmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Content="检查"
                                                    Style="{StaticResource CompactOutlineButtonStyle}" />
                                            <Button Width="112"
                                                    Margin="8,0,0,0"
                                                    Command="{Binding DataContext.BuildTensorRtCacheCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Content="构建 Cache"
                                                    Style="{StaticResource CompactOutlineButtonStyle}" />
                                        </StackPanel>

                                        <TextBox Grid.Row="1"
                                                 Margin="0,10,0,0"
                                                 MinHeight="76"
                                                 IsReadOnly="True"
                                                 Background="#F6F8FA"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto">
                                            <TextBox.Text>
                                                <MultiBinding Mode="OneWay" StringFormat="{}{0}&#x0a;{1}">
                                                    <Binding Mode="OneWay" Path="TensorRtCacheStatusText" />
                                                    <Binding Mode="OneWay" Path="DataContext.ModelEnvironmentStatus" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBox.Text>
                                        </TextBox>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Margin="0,12,0,0"
                                          Header="U-Net Segmentation"
                                          Visibility="{Binding IsUnetSegmentation, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Probability threshold" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding UnetProbabilityThresholdText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Column="3" Style="{StaticResource FieldLabelStyle}" Text="Min component area" />
                                        <TextBox Grid.Column="4"
                                                 Text="{Binding UnetMinComponentAreaText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Min perimeter" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,12,0,0"
                                                 Text="{Binding UnetMinComponentPerimeterText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="1" Grid.Column="3" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Min area/perimeter" />
                                        <TextBox Grid.Row="1"
                                                 Grid.Column="4"
                                                 Margin="0,12,0,0"
                                                 Text="{Binding UnetMinAreaPerimeterRatioText, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource FieldLabelStyle}" Text="Max area/perimeter" />
                                        <TextBox Grid.Row="2"
                                                 Grid.Column="1"
                                                 Margin="0,12,0,0"
                                                 Text="{Binding UnetMaxAreaPerimeterRatioText, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Margin="0,12,0,0" Header="Model Metadata">
                                    <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding MetadataRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="{Binding Label}" />
                                                    <TextBlock Grid.Column="1"
                                                               Foreground="{StaticResource PanelTitleBrush}"
                                                               Text="{Binding Value}"
                                                               TextWrapping="Wrap" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </GroupBox>

                            </StackPanel>
                        </ScrollViewer>

                        
                    </Grid>
                </materialDesign:Card>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1"
                Margin="0,8,0,0"
                Padding="12"
                Background="#EEF3F8"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <Button Width="180"
                    HorizontalAlignment="Right"
                    Command="{Binding SaveCommand}"
                    Content="Save Task Configuration"
                    Style="{StaticResource CompactOutlineButtonStyle}" />
        </Border>
    </Grid>
</Window>

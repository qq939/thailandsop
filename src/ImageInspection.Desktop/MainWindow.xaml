<Window x:Class="VideoInferenceDemo.ImageInspection.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:controls="clr-namespace:VideoInferenceDemo.ImageInspection.Controls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Width="1380"
        Height="860"
        MinWidth="1200"
        MinHeight="760"
        Icon="Assets/AppIcon.ico"
        Background="#F3F6FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="WorkspaceTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D6E0EA" />
            <Setter Property="Background" Value="#F7FAFD" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#AFC2D4" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#EEF4FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#16324F">
            <Grid Margin="18,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="52" Margin="0,0,12,0" Background="Transparent">
                        <Image Source="Assets/AMSLogo.png"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>
                    <StackPanel>
                        <TextBlock FontSize="17" FontWeight="SemiBold" Foreground="White" Text="{Binding HomeTitle}" />
                        <TextBlock Foreground="#C9D8E6" Text="{Binding RuntimeStatusText}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                        <materialDesign:PackIcon Kind="AccountCircle"
                                                 Width="20"
                                                 Height="20"
                                                 Foreground="#8FCAFF"
                                                 VerticalAlignment="Center" />
                        <Border MinWidth="170"
                                Margin="8,0,0,0"
                                Padding="10,5"
                                Background="#1E3D5F"
                                BorderBrush="#3D6E9E"
                                BorderThickness="1"
                                CornerRadius="14">
                            <TextBlock Foreground="White"
                                       Text="{Binding CurrentLoginDisplayText}"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding CurrentLoginDisplayText}" />
                        </Border>
                        <Button MinWidth="68"
                                Height="32"
                                Margin="10,0,0,0"
                                Command="{Binding LoginCommand}"
                                Content="登录"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="White"
                                BorderBrush="#3D6E9E" />
                        <Button MinWidth="68"
                                Height="32"
                                Margin="8,0,0,0"
                                Command="{Binding LogoutCommand}"
                                Content="注销"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Foreground="White"
                                BorderBrush="#3D6E9E" />
                    </StackPanel>
                    <materialDesign:PopupBox PlacementMode="BottomAndAlignRightEdges" StaysOpen="False">
                        <materialDesign:PopupBox.ToggleContent>
                            <Border Width="34" Height="34" Background="#284766" CornerRadius="17">
                                <materialDesign:PackIcon Width="18"
                                                         Height="18"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="#D5E1ED"
                                                         Kind="DotsVertical" />
                            </Border>
                        </materialDesign:PopupBox.ToggleContent>
                        <Border Width="220" Padding="10" Background="White" CornerRadius="10">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,10"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#223446"
                                           Text="设置菜单" />
                                <Button Margin="0,0,0,6"
                                        Command="{Binding OpenCameraSettingsCommand}"
                                        Content="相机设置"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <Button Margin="0,0,0,6"
                                        Command="{Binding OpenTaskSettingsCommand}"
                                        Content="任务配置"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <Button Margin="0,0,0,6"
                                        Command="{Binding OpenRoiSettingsCommand}"
                                        Content="ROI 设置"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <Button Margin="0,0,0,6"
                                        Command="{Binding OpenPersonnelManagementCommand}"
                                        Content="人员管理"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                                <Button Command="{Binding OpenParameterSettingsCommand}"
                                        Content="参数设置"
                                        Style="{StaticResource MaterialDesignOutlinedButton}" />
                            </StackPanel>
                        </Border>
                    </materialDesign:PopupBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.15*" />
                <ColumnDefinition Width="1.02*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,18,0"
                    Padding="8"
                    Background="White"
                    BorderBrush="#D6E0EA"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ListBox Grid.Row="0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource WorkspaceTabItemStyle}"
                             ItemsSource="{Binding WorkspaceTabs}"
                             SelectedItem="{Binding SelectedWorkspaceTab}">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Title}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="1" Margin="0,6,0,0" DataContext="{Binding SelectedWorkspaceTab}">
                        <controls:CameraViewportGrid Cameras="{Binding DataContext.CameraSessions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Columns="{Binding DataContext.OverviewColumns, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     SelectCommand="{Binding DataContext.SelectCameraCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Visibility="{Binding IsOverview, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <controls:CameraViewportGrid Cameras="{Binding Task.Cameras}"
                                                     Columns="{Binding Task.GridColumns}"
                                                     SelectCommand="{Binding DataContext.SelectCameraCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Visibility="{Binding IsTask, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <controls:CameraViewportTile Camera="{Binding Camera}"
                                                     SelectCommand="{Binding DataContext.SelectCameraCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                     Visibility="{Binding IsCamera, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Padding="8"
                    Background="#EEF3F8"
                    BorderBrush="#D6E0EA"
                    BorderThickness="1"
                    CornerRadius="14"
                    DataContext="{Binding ActiveSidePanel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel TextElement.FontFamily="Microsoft YaHei">
                        <Border Padding="14"
                                Background="White"
                                BorderBrush="#D7E1EA"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#203243"
                                           Text="{Binding Title}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#617587"
                                           Text="{Binding Subtitle}" />

                                <StackPanel Margin="0,14,0,0"
                                            Visibility="{Binding IsOverview, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <UniformGrid Margin="0,0,0,14" Columns="2">
                                        <Button Margin="0,0,8,0"
                                                Command="{Binding DataContext.StartAllTasksCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="全部启动"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                        <Button Command="{Binding DataContext.StopAllTasksCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="全部停止"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </UniformGrid>

                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#203243"
                                               Text="任务" />
                                    <ItemsControl Margin="0,8,0,12" ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="12"
                                                        Background="#F8FBFD"
                                                        BorderBrush="#D5E0EA"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <StackPanel>
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Left"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#203243"
                                                                       Text="{Binding Name}" />
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Foreground="#607488"
                                                                       Text="{Binding CameraSummary}" />
                                                        </DockPanel>

                                                        <TextBlock Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#607488"
                                                                   Text="&#x68C0;&#x6D4B;&#x7ED3;&#x679C;" />
                                                        <Border Margin="0,4,0,0"
                                                                Padding="12,8"
                                                                Background="{Binding ResultBackground}"
                                                                CornerRadius="8">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       FontSize="22"
                                                                       FontWeight="Bold"
                                                                       Foreground="{Binding ResultForeground}"
                                                                       Text="{Binding ResultText}" />
                                                        </Border>

                                                        <TextBlock Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#607488"
                                                                   Text="&#x901A;&#x8BAF;&#x89E6;&#x53D1;&#x72B6;&#x6001;" />
                                                        <Border Margin="0,4,0,0"
                                                                Padding="10,7"
                                                                Background="{Binding TriggerStatusBackground}"
                                                                CornerRadius="8">
                                                            <TextBlock FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding TriggerStatusForeground}"
                                                                       Text="{Binding TriggerStatusText}"
                                                                       TextWrapping="Wrap" />
                                                        </Border>

                                                        <TextBlock Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#607488"
                                                                   Text="&#x68C0;&#x6D4B;&#x8017;&#x65F6;" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#4C6072"
                                                                   Text="{Binding TimingText}"
                                                                   TextWrapping="Wrap" />

                                                        <TextBlock Margin="0,10,0,0"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#607488"
                                                                   Text="&#x68C0;&#x6D4B;&#x6982;&#x8981;" />
                                                        <TextBlock Margin="0,4,0,0"
                                                                   Foreground="#4C6072"
                                                                   Text="{Binding SummaryMessage}"
                                                                   TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>

                                <StackPanel Margin="0,14,0,0"
                                            Visibility="{Binding IsTask, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Foreground="#607488" Text="任务" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#203243"
                                                       Text="{Binding Task.RecipeTaskId}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Foreground="#607488" Text="Action" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#203243"
                                                       Text="{Binding Task.ActionType}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,8,8">
                                            <TextBlock Foreground="#607488" Text="产品型号" />
                                            <TextBox Text="{Binding DataContext.RuntimeProductModel, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock Foreground="#607488" Text="位置号" />
                                            <TextBox Text="{Binding DataContext.RuntimePositionNo, RelativeSource={RelativeSource AncestorType=Window}, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Margin="0,8,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#203243"
                                               Text="相机图片" />
                                    <ItemsControl Margin="0,8,0,16" ItemsSource="{Binding Cameras}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,8"
                                                        Padding="10"
                                                        Background="#F8FBFD"
                                                        BorderBrush="#D5E0EA"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Foreground="#203243"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Name}" />
                                                        <TextBlock Grid.Row="1"
                                                                   Margin="0,4,8,0"
                                                                   Foreground="#607488"
                                                                   Text="{Binding StatusText}"
                                                                   TextWrapping="Wrap" />
                                                        <UniformGrid Grid.Column="1"
                                                                     Grid.RowSpan="2"
                                                                     Margin="10,0,0,0"
                                                                     Columns="2">
                                                            <Button Margin="0,0,6,0"
                                                                    Padding="12,0"
                                                                    Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="打开"
                                                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                                                            <Button Padding="12,0"
                                                                    Command="{Binding DataContext.InspectOpenedImageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="检测"
                                                                    Style="{StaticResource MaterialDesignOutlinedButton}" />
                                                        </UniformGrid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <UniformGrid Margin="0,0,0,16" Columns="3">
                                        <Button Margin="0,0,8,0"
                                                Command="{Binding DataContext.StartTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="启动"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                        <Button Margin="0,0,8,0"
                                                Command="{Binding DataContext.StopTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="停止"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                        <Button Command="{Binding DataContext.ManualTriggerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Content="手动触发"
                                                IsEnabled="{Binding Task.CanTrigger}"
                                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    </UniformGrid>

                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="#203243"
                                               Text="检测概要" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#4C6072"
                                               Text="{Binding Task.SummaryMessage}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#203243"
                                               Text="检测耗时" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#4C6072"
                                               Text="{Binding Task.TimingText}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,14,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#203243"
                                               Text="&#x68C0;&#x6D4B;&#x7ED3;&#x679C;" />
                                    <Border Margin="0,8,0,0"
                                            Padding="14,10"
                                            Background="{Binding Task.ResultBackground}"
                                            CornerRadius="8">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="{Binding Task.ResultForeground}"
                                                   Text="{Binding Task.ResultText}" />
                                    </Border>
                                    <TextBlock Margin="0,14,0,0"
                                               FontWeight="SemiBold"
                                               Foreground="#203243"
                                               Text="&#x901A;&#x8BAF;&#x89E6;&#x53D1;&#x72B6;&#x6001;" />
                                    <Border Margin="0,8,0,0"
                                            Padding="12,8"
                                            Background="{Binding Task.TriggerStatusBackground}"
                                            CornerRadius="8">
                                        <TextBlock FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding Task.TriggerStatusForeground}"
                                                   Text="{Binding Task.TriggerStatusText}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>

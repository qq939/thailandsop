<Window x:Class="VideoInferenceDemo.ImageInspection.Camera.InspectionCameraConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="相机设置"
        Height="780"
        Width="1120"
        MinHeight="720"
        MinWidth="1000"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Margin="0,0,0,10"
                Padding="14,10"
                Background="#EEF3F8"
                BorderBrush="#D6E0EA"
                BorderThickness="1"
                CornerRadius="14">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#1F2937" Text="相机设置" />
        </Border>

        <materialDesign:Card Grid.Row="1" Grid.Column="0" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Margin="0,0,0,10"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           Text="相机列表" />

                <ListBox Grid.Row="1"
                         Margin="0,6,0,12"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Cameras}"
                         SelectedItem="{Binding SelectedCamera}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="#F8FAFC" />
                            <Setter Property="BorderBrush" Value="#DCE4ED" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="SelectionChrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="12"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="SelectionChrome" Property="Background" Value="#DCEEFE" />
                                                <Setter TargetName="SelectionChrome" Property="BorderBrush" Value="#0F5A91" />
                                                <Setter TargetName="SelectionChrome" Property="BorderThickness" Value="2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="14"
                                    Background="Transparent"
                                    CornerRadius="12">
                                <StackPanel>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock DockPanel.Dock="Left"
                                                   FontSize="13.5"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding SidebarTitle}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#1F2937" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="#0B5CAD" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border DockPanel.Dock="Right"
                                                Padding="8,2"
                                                CornerRadius="10">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#EDF6EE" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#C8E0F8" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="11" Text="{Binding SidebarStateText}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#2F6F44" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="#0B5CAD" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DockPanel>

                                    <TextBlock Margin="0,6,0,0"
                                               Text="{Binding SidebarSubtitle}"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#667085" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="#335E82" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="11.5"
                                               Text="{Binding SaveModeText}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#8B95A1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="#4C7396" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Width="42"
                            Height="42"
                            Margin="0,0,8,0"
                            Padding="0"
                            Command="{Binding AddCameraCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            ToolTip="新增相机">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" />
                    </Button>
                    <Button Width="42"
                            Height="42"
                            Margin="0,0,8,0"
                            Padding="0"
                            Command="{Binding RemoveCameraCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            ToolTip="删除当前相机">
                        <materialDesign:PackIcon Kind="Minus" Width="18" Height="18" />
                    </Button>
                    <Button Width="42"
                            Height="42"
                            Padding="0"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            ToolTip="保存设置">
                        <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" />
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" Grid.Column="2" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" DataContext="{Binding SelectedCamera}">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Text="当前相机" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" Foreground="#667085" Text="名称" />
                        <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="启用" />
                        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" IsChecked="{Binding Enabled}" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="Provider" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding DataContext.CameraProviders, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedValue="{Binding SelectedProviderId, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="ProviderId" />

                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="触发模式" />
                        <ComboBox Grid.Row="3"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding TriggerModes}"
                                  SelectedValue="{Binding SelectedTriggerMode, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Mode" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   Foreground="#667085"
                                   Margin="0,12,0,0"
                                   Text="相机索引"
                                   Visibility="{Binding IsOpenCvProvider, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBox Grid.Row="4"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 Text="{Binding CameraIndex, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsOpenCvProvider, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Grid.Row="5"
                                   VerticalAlignment="Center"
                                   Foreground="#667085"
                                   Margin="0,12,0,0"
                                   Text="设备标识"
                                   Visibility="{Binding UsesDeviceIdentifiers, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <Grid Grid.Row="5"
                              Grid.Column="1"
                              Margin="0,12,0,0"
                              Visibility="{Binding UsesDeviceIdentifiers, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox IsEditable="True"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding AvailableDevices}"
                                      SelectedItem="{Binding SelectedDevice}"
                                      Text="{Binding DeviceId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding HasDiscoveredDevices}" />
                            <Button Grid.Column="2"
                                    Command="{Binding RefreshDevicesCommand}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="Refresh" />
                                    <TextBlock Text="刷新" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   Foreground="#667085"
                                   Margin="0,12,0,0"
                                   Text="OpenCV 源"
                                   Visibility="{Binding IsOpenCvProvider, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBox Grid.Row="6"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 Text="{Binding OpenCvSource, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsOpenCvProvider, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <TextBlock Grid.Row="7"
                                   VerticalAlignment="Center"
                                   Foreground="#667085"
                                   Margin="0,12,0,0"
                                   Text="OpenCV 后端"
                                   Visibility="{Binding IsOpenCvProvider, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBox Grid.Row="7"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 Text="{Binding OpenCvBackend, UpdateSourceTrigger=PropertyChanged}"
                                 Visibility="{Binding IsOpenCvProvider, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <TextBlock Margin="0,20,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Text="图片保存" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" Foreground="#667085" Text="保存图片" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding SaveImages}" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="保存 ROI" />
                        <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" IsChecked="{Binding SaveRoiImages}" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="保存目录" />
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ImageSaveDirectory, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Command="{Binding DataContext.BrowseImageSaveDirectoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Width="16" Height="16" Margin="0,0,6,0" Kind="FolderOpen" />
                                    <TextBlock Text="选择" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="命名模板" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="{Binding ImageFileNamePattern, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>
    </Grid>
</Window>

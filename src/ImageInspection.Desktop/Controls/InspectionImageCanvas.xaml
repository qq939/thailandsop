<UserControl x:Class="VideoInferenceDemo.ImageInspection.Controls.InspectionImageCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VideoInferenceDemo.ImageInspection.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:imageBox="clr-namespace:ImageBox;assembly=ImageBox"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:Name="Root"
             MinWidth="320"
             MinHeight="220"
             mc:Ignorable="d">
    <imageBox:ImageBoxControl HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              OverlayItems="{Binding OverlayItems, RelativeSource={RelativeSource AncestorType={x:Type controls:InspectionImageCanvas}}}"
                              ImageSource="{Binding ImageSource, RelativeSource={RelativeSource AncestorType={x:Type controls:InspectionImageCanvas}}}" />
</UserControl>

<Window x:Class="VideoInferenceDemo.ImageInspection.Settings.InspectionParameterSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="参数设置"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Segoe UI">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Background="#EEF3F8"
                BorderBrush="#D6E0EA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#1F2937" Text="参数设置" />
        </Border>

        <materialDesign:Card Grid.Row="1" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Text="结果存储" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" Foreground="#667085" Text="数据库类型" />
                        <ComboBox Grid.Column="1"
                                  SelectedValue="{Binding DatabaseProvider, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="SQLite" />
                            <ComboBoxItem Content="MySQL" />
                        </ComboBox>

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="连接字符串" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding ConnectionString, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="保存快照" />
                        <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" IsChecked="{Binding SaveSnapshots}" />

                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="快照目录" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="{Binding SnapshotDirectory, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="Retention days" />
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Text="{Binding RetentionDaysText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="5" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="Auto cleanup" />
                        <CheckBox Grid.Row="5" Grid.Column="1" Margin="0,12,0,0" IsChecked="{Binding EnableAutoCleanup}" />
                    </Grid>

                    <TextBlock Margin="0,22,0,0" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Text="通讯输出" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" Foreground="#667085" Text="协议类型" />
                        <TextBox Grid.Column="1" Text="{Binding ProtocolType, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="目标地址" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding ProtocolEndpoint, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="发布结果" />
                        <CheckBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" IsChecked="{Binding PublishResults}" />
                    </Grid>

                    <TextBlock Margin="0,22,0,0"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               Text="PLC&#x89E6;&#x53D1;&#x8F93;&#x5165;" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" Foreground="#667085" Text="&#x542F;&#x7528;&#x89E6;&#x53D1;" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding PlcTriggerEnabled}" />

                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Foreground="#667085" Text="PLC&#x5730;&#x5740;" />
                        <TextBox Grid.Column="3" Text="{Binding PlcTriggerHost, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="&#x7AEF;&#x53E3;" />
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Text="{Binding PlcTriggerPortText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="&#x4EFB;&#x52A1;&#x540D;&#x79F0;" />
                        <TextBox Grid.Row="1" Grid.Column="3" Margin="0,12,0,0" Text="{Binding PlcTriggerTaskName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="&#x89E6;&#x53D1;&#x5BC4;&#x5B58;&#x5668;" />
                        <TextBox Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Text="{Binding PlcTriggerRegisterAddressText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2" Grid.Column="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="Done&#x5BC4;&#x5B58;&#x5668;" />
                        <TextBox Grid.Row="2" Grid.Column="3" Margin="0,12,0,0" Text="{Binding PlcDoneRegisterAddressText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="Result&#x5BC4;&#x5B58;&#x5668;" />
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Text="{Binding PlcResultRegisterAddressText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3" Grid.Column="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="&#x8F6E;&#x8BE2;ms" />
                        <TextBox Grid.Row="3" Grid.Column="3" Margin="0,12,0,0" Text="{Binding PlcTriggerPollIntervalMsText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="&#x8BFB;&#x8D85;&#x65F6;ms" />
                        <TextBox Grid.Row="4" Grid.Column="1" Margin="0,12,0,0" Text="{Binding PlcReadTimeoutMsText, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4" Grid.Column="2" VerticalAlignment="Center" Foreground="#667085" Margin="0,12,0,0" Text="&#x5199;&#x8D85;&#x65F6;ms" />
                        <TextBox Grid.Row="4" Grid.Column="3" Margin="0,12,0,0" Text="{Binding PlcWriteTimeoutMsText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>

        <StackPanel Grid.Row="2" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button IsCancel="True" MinWidth="96" Margin="0,0,8,0" Style="{StaticResource MaterialDesignOutlinedButton}" Content="取消" />
            <Button Command="{Binding SaveCommand}" MinWidth="108" Style="{StaticResource MaterialDesignRaisedButton}" Content="保存" />
        </StackPanel>
    </Grid>
</Window>

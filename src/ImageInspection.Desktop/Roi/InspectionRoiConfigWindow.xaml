<Window x:Class="VideoInferenceDemo.ImageInspection.Roi.InspectionRoiConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VideoInferenceDemo.ImageInspection.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ROI 设置"
        Width="1320"
        Height="860"
        MinWidth="1160"
        MinHeight="740"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei"
        FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7E1EA" />
        <SolidColorBrush x:Key="PanelTitleBrush" Color="#203243" />
        <SolidColorBrush x:Key="PanelSubtleTextBrush" Color="#607488" />

        <Style x:Key="PanelCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource PanelTitleBrush}" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Foreground" Value="{StaticResource PanelSubtleTextBrush}" />
        </Style>

        <Style x:Key="IconActionButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.02*" />
            </Grid.ColumnDefinitions>

            <controls:InspectionImageCanvas Grid.Column="0"
                                            ImageSource="{Binding PreviewImage}"
                                            OverlayItems="{Binding OverlayItems}" />

            <Border Grid.Column="2"
                    Padding="8"
                    Background="#EEF3F8"
                    BorderBrush="#D6E0EA"
                    BorderThickness="1"
                    CornerRadius="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Margin="0,0,0,10" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{StaticResource PanelSubtleTextBrush}"
                                           Text="{Binding DataContext.CoordinateHintText, RelativeSource={RelativeSource AncestorType=Window}}"
                                           TextWrapping="Wrap" />
                                <TextBlock Style="{StaticResource PanelTitleStyle}" Text="图像操作" />
                                <TextBox Margin="0,12,0,8"
                                         IsReadOnly="True"
                                         Text="{Binding ReferenceImagePath}" />
                                <UniformGrid Columns="3">
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding PickReferenceImageCommand}"
                                            Content="读取图像"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    <Button Margin="0,0,8,0"
                                            Command="{Binding ClearReferenceImageCommand}"
                                            Content="清除图像"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                                    <Button Command="{Binding PickReferenceImageCommand}"
                                            Content="替换图像"
                                            Style="{StaticResource MaterialDesignOutlinedButton}" />
                                </UniformGrid>
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,0,10" Style="{StaticResource PanelCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource PanelTitleStyle}" Text="ROI 管理" />
                                <TextBlock Margin="0,10,0,4"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Text="任务 / 产品号 / 位置号" />
                                <ComboBox DisplayMemberPath="DisplayName"
                                          IsEnabled="{Binding CanSwitchContext}"
                                          ItemsSource="{Binding Contexts}"
                                          SelectedItem="{Binding SelectedContext}" />
                                <TextBlock Margin="0,10,0,4"
                                           Style="{StaticResource FieldLabelStyle}"
                                           Text="相机" />
                                <ComboBox DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding AvailableCameras}"
                                          SelectedItem="{Binding SelectedCamera}" />

                                <Border Margin="0,14,0,0"
                                        Padding="10"
                                        Background="#F7FCFA"
                                        BorderBrush="#B7E4D2"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        DataContext="{Binding SelectedAlignment}">
                                    <StackPanel>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Left"
                                                       FontWeight="SemiBold"
                                                       Foreground="#145A43"
                                                       Text="全局定位" />
                                            <CheckBox DockPanel.Dock="Right"
                                                      Content="启用"
                                                      IsChecked="{Binding Enabled}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,6,0,8"
                                                   Foreground="#5A7468"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="定位模型" />
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding DataContext.AvailableLocatorModels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedValue="{Binding LocatorModelId, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Id" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="定位类别" />
                                                <ComboBox DisplayMemberPath="DisplayName"
                                                          ItemsSource="{Binding DataContext.AvailableLocatorClasses, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          SelectedItem="{Binding DataContext.SelectedLocatorClass, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="中心 X (px)" />
                                                <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Text="{Binding CenterXText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="中心 Y (px)" />
                                                <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Text="{Binding CenterYText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,8">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="宽度 (px)" />
                                                <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Text="{Binding WidthText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,0,8">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="高度 (px)" />
                                                <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                         Text="{Binding HeightText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Style="{StaticResource FieldLabelStyle}" Text="角度" />
                                                <TextBox Text="{Binding AngleDegText, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>

                                <DockPanel Margin="0,16,0,12">
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Style="{StaticResource PanelTitleStyle}" Text="当前 ROI 列表" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource PanelSubtleTextBrush}"
                                                   Text="{Binding Rois.Count, StringFormat=共 {0} 个 ROI}" />
                                    </StackPanel>
                                    <StackPanel DockPanel.Dock="Right"
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="0,0,6,0"
                                                Command="{Binding AddRoiCommand}"
                                                Style="{StaticResource IconActionButtonStyle}"
                                                ToolTip="新增 ROI">
                                            <materialDesign:PackIcon Width="15" Height="15" Kind="Plus" />
                                        </Button>
                                        <Button Margin="0,0,6,0"
                                                Command="{Binding DuplicateRoiCommand}"
                                                Style="{StaticResource IconActionButtonStyle}"
                                                ToolTip="复制 ROI">
                                            <materialDesign:PackIcon Width="15" Height="15" Kind="ContentCopy" />
                                        </Button>
                                        <Button Command="{Binding RemoveRoiCommand}"
                                                Style="{StaticResource IconActionButtonStyle}"
                                                ToolTip="删除 ROI">
                                            <materialDesign:PackIcon Width="15"
                                                                     Height="15"
                                                                     Foreground="#B42318"
                                                                     Kind="DeleteOutline" />
                                        </Button>
                                    </StackPanel>
                                </DockPanel>

                                <ListBox ItemsSource="{Binding Rois}" SelectedItem="{Binding SelectedRoi}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="10"
                                                    Background="#F8FBFD"
                                                    BorderBrush="#D5E0EA"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold"
                                                               Foreground="#203243"
                                                               Text="{Binding Name}" />
                                                    <TextBlock Margin="0,3,0,0"
                                                               Foreground="#617587"
                                                               Text="{Binding Summary}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource PanelCardStyle}" DataContext="{Binding SelectedRoi}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource PanelTitleStyle}" Text="当前 ROI 参数" />
                                <UniformGrid Margin="0,12,0,0" Columns="2">
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="名称" />
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="启用" />
                                        <CheckBox IsChecked="{Binding Enabled}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="中心 X (px)" />
                                        <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Text="{Binding CenterXText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="中心 Y (px)" />
                                        <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Text="{Binding CenterYText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="宽度 (px)" />
                                        <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Text="{Binding WidthText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="高度 (px)" />
                                        <TextBox IsEnabled="{Binding DataContext.HasReferenceImage, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Text="{Binding HeightText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="旋转角度" />
                                        <TextBox Text="{Binding AngleDegText, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="模型" />
                                        <ComboBox DisplayMemberPath="DisplayName"
                                                  ItemsSource="{Binding DataContext.AvailableModels, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedValue="{Binding ModelId, UpdateSourceTrigger=PropertyChanged}"
                                                  SelectedValuePath="Id" />
                                    </StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Margin="0,12,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button IsCancel="True"
                    MinWidth="96"
                    Margin="0,0,8,0"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Content="取消" />
            <Button Command="{Binding SaveCommand}"
                    MinWidth="108"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="VideoInferenceDemo.ProductionDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="生产统计看板"
        Width="1260"
        Height="780"
        MinWidth="1080"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Padding="14" Margin="0,0,0,12" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#20364A" Text="生产统计看板" />
                    <WrapPanel Margin="0,10,0,0" VerticalAlignment="Center">
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#5E6B79" Text="开始" />
                        <DatePicker Width="130" Margin="0,0,12,0" SelectedDate="{Binding FromDate, Mode=TwoWay}" />
                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#5E6B79" Text="结束" />
                        <DatePicker Width="130" Margin="0,0,12,0" SelectedDate="{Binding ToDate, Mode=TwoWay}" />

                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#5E6B79" Text="员工" />
                        <ComboBox Width="210"
                                  Margin="0,0,12,0"
                                  ItemsSource="{Binding EmployeeFilters}"
                                  SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayText" />

                        <TextBlock Margin="0,0,8,0" VerticalAlignment="Center" Foreground="#5E6B79" Text="班组" />
                        <ComboBox Width="150"
                                  Margin="0,0,12,0"
                                  ItemsSource="{Binding TeamFilters}"
                                  SelectedItem="{Binding SelectedTeam, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayText" />

                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button MinWidth="92" Margin="0,0,10,0" Padding="12,4" Command="{Binding RefreshCommand}" Content="刷新" />
                    <Button MinWidth="92" Padding="12,4" Command="{Binding ExportCsvCommand}" Content="导出 CSV" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="10" Background="#EEF5FF">
                <StackPanel>
                    <TextBlock Foreground="#4E6177" Text="作业次数" />
                    <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="#203B56" Text="{Binding TotalRunCount}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="1" Margin="0,0,8,0" Padding="10" Background="#EAF7EF">
                <StackPanel>
                    <TextBlock Foreground="#4E7B60" Text="OK 数量" />
                    <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="#177245" Text="{Binding TotalOkCount}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2" Margin="0,0,8,0" Padding="10" Background="#FDF0F0">
                <StackPanel>
                    <TextBlock Foreground="#8F5F5F" Text="NG 数量" />
                    <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="#A64040" Text="{Binding TotalNgCount}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="3" Margin="0,0,8,0" Padding="10" Background="#F5F2FF">
                <StackPanel>
                    <TextBlock Foreground="#625792" Text="总作业时长" />
                    <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="#4C3A8A" Text="{Binding TotalWorkDurationText}" />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="4" Padding="10" Background="#F1F8FF">
                <StackPanel>
                    <TextBlock Foreground="#4E6177" Text="综合良率" />
                    <TextBlock Margin="0,6,0,0" FontSize="24" FontWeight="Bold" Foreground="#0F5A91" Text="{Binding OverallYieldText}" />
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <materialDesign:Card Grid.Row="2" Padding="10" Background="White">
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="工号" Width="120" Binding="{Binding EmployeeCode}" />
                    <DataGridTextColumn Header="姓名" Width="120" Binding="{Binding EmployeeName}" />
                    <DataGridTextColumn Header="作业次数" Width="90" Binding="{Binding RunCount}" />
                    <DataGridTextColumn Header="总作业时长" Width="120" Binding="{Binding TotalWorkDurationText}" />
                    <DataGridTextColumn Header="平均作业时长" Width="120" Binding="{Binding AvgWorkDurationText}" />
                    <DataGridTextColumn Header="OK 数量" Width="90" Binding="{Binding OkCount}" />
                    <DataGridTextColumn Header="NG 数量" Width="90" Binding="{Binding NgCount}" />
                    <DataGridTextColumn Header="良率" Width="90" Binding="{Binding YieldText}" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="3" Padding="12" Margin="0,12,0,0" Background="White">
            <TextBlock Foreground="#5E6B79" Text="{Binding StatusText}" />
        </materialDesign:Card>
    </Grid>
</Window>

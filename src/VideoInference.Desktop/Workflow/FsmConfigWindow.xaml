<Window x:Class="VideoInferenceDemo.FsmConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="操作状态配置"
        Height="620"
        Width="980"
        MinHeight="560"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Background="#EEF3F8"
                BorderBrush="#D6E0EA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="操作状态配置"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#D6E0EA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="步骤数量"
                                   Foreground="#667085"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Steps.Count}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#0F5A91"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <materialDesign:Card Grid.Row="1" Padding="14">
            <DataGrid ItemsSource="{Binding Steps}"
                      SelectedItem="{Binding SelectedStep}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      Background="Transparent"
                      BorderThickness="0"
                      RowBackground="#F8FAFC"
                      AlternatingRowBackground="#FFFFFF"
                      materialDesign:DataGridAssist.CellPadding="10,6"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="10,6">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="步骤"
                                        Binding="{Binding Step}"
                                        IsReadOnly="True"
                                        Width="70" />
                    <DataGridTextColumn Header="名称"
                                        Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                        Width="2*" />
                    <DataGridTextColumn Header="动作编码"
                                        Binding="{Binding ActionCode, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="目标状态"
                                        Binding="{Binding ExpectedStateCode, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="TCN 标签"
                                        Binding="{Binding TcnLabel, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <TextBlock Grid.Row="2"
                   Text="{Binding ErrorMessage}"
                   Foreground="#B00020"
                   Margin="0,8,0,0" />

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button Content="新增"
                        Command="{Binding AddStepCommand}"
                        Style="{StaticResource SecondaryDialogButtonStyle}" />
                <Button Content="删除"
                        Command="{Binding RemoveSelectedCommand}"
                        Style="{StaticResource SecondaryDialogButtonStyle}" />
                <Button Content="上移"
                        Command="{Binding MoveUpCommand}"
                        Style="{StaticResource SecondaryDialogButtonStyle}" />
                <Button Content="下移"
                        Command="{Binding MoveDownCommand}"
                        Style="{StaticResource SecondaryDialogButtonStyle}"
                        Margin="0" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="保存"
                        Click="OnSave"
                        Style="{StaticResource PrimaryDialogButtonStyle}" />
                <Button Content="取消"
                        Click="OnCancel"
                        Style="{StaticResource SecondaryDialogButtonStyle}"
                        Margin="0" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

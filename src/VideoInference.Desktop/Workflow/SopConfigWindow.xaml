<Window x:Class="VideoInferenceDemo.SopConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="SOP 配置"
        Height="700"
        Width="1060"
        MinHeight="600"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="IconToolButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE4ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="SidebarCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#DCE4ED" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="3"
                Margin="0,0,0,10"
                Background="#EEF3F8"
                BorderBrush="#D6E0EA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="SOP 配置管理"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#1F2937" />
                    <TextBlock Text="SOP 配置与 Action 策略一对一绑定。每个相机选择一个 SOP 配置。"
                               Foreground="#667085"
                               FontSize="12"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#FFFFFF"
                        BorderBrush="#D6E0EA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,8"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="配置数量"
                                   Foreground="#667085"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding Profiles.Count}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#0F5A91"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Left sidebar: SOP profile list -->
        <materialDesign:Card Grid.Row="1" Grid.Column="0" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="SOP 配置列表" Style="{StaticResource SectionTitleStyle}" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,6,0,12"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="#F8FAFC" />
                            <Setter Property="BorderBrush" Value="#DCE4ED" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="SelectionChrome"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="10"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="SelectionChrome" Property="Background" Value="#DCEEFE" />
                                                <Setter TargetName="SelectionChrome" Property="BorderBrush" Value="#0F5A91" />
                                                <Setter TargetName="SelectionChrome" Property="BorderThickness" Value="2" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12" CornerRadius="8" Background="Transparent">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#1F2937" />
                                    <TextBlock Text="{Binding Strategy}"
                                               Foreground="#667085"
                                               FontSize="11.5"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding Steps.Count, StringFormat={}{0} 个步骤}"
                                               Foreground="#8B95A1"
                                               FontSize="11"
                                               Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding AddProfileCommand}"
                                Style="{StaticResource IconToolButtonStyle}"
                                ToolTip="新增 SOP 配置">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" />
                        </Button>
                        <Button Command="{Binding RemoveProfileCommand}"
                                Style="{StaticResource IconToolButtonStyle}"
                                ToolTip="删除当前配置">
                            <materialDesign:PackIcon Kind="Minus" Width="18" Height="18" />
                        </Button>
                        <Button Style="{StaticResource IconToolButtonStyle}"
                                ToolTip="保存配置"
                                Click="OnSave">
                            <materialDesign:PackIcon Kind="ContentSave" Width="18" Height="18" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </materialDesign:Card>

        <!-- Right panel: edit selected profile -->
        <materialDesign:Card Grid.Row="1" Grid.Column="2" Padding="20">
            <Grid>
                <!-- No selection hint -->
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#667085"
                           FontSize="14"
                           Text="请先在左侧选择一个 SOP 配置。">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedProfile}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              DataContext="{Binding SelectedProfile}"
                              Visibility="{Binding DataContext.HasSelectedProfile, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <!-- Profile basic info -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="基本信息" Style="{StaticResource SectionTitleStyle}" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="名称" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Width="220"
                                             HorizontalAlignment="Left" />

                                    <TextBlock Grid.Row="1"
                                               Text="策略"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0,12,0,0" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              Margin="0,12,0,0"
                                              Width="220"
                                              HorizontalAlignment="Left"
                                              ItemsSource="{Binding DataContext.StrategyOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              SelectedItem="{Binding Strategy}" />

                                    <TextBlock Grid.Row="2"
                                               Text="指纹模块"
                                               Style="{StaticResource FieldLabelStyle}"
                                               Margin="0,12,0,0" />
                                    <ComboBox Grid.Row="2"
                                              Grid.Column="1"
                                              Margin="0,12,0,0"
                                              Width="260"
                                              HorizontalAlignment="Left"
                                              ItemsSource="{Binding DataContext.FingerprintModuleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding FingerprintModuleId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Steps editing -->
                        <Border Style="{StaticResource SectionCardStyle}" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="步骤列表" Style="{StaticResource SectionTitleStyle}" />

                                <Border Background="#FFFFFF"
                                        BorderBrush="#E3EAF1"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="4"
                                        Margin="0,0,16,0">
                                    <DataGrid ItemsSource="{Binding Steps}"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              HeadersVisibility="Column"
                                              RowHeaderWidth="0"
                                              GridLinesVisibility="All"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              RowBackground="#F8FAFC"
                                              AlternatingRowBackground="#FFFFFF"
                                              materialDesign:DataGridAssist.CellPadding="8,4"
                                              materialDesign:DataGridAssist.ColumnHeaderPadding="8,6"
                                              MaxHeight="360">
                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </DataGrid.CellStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#"
                                                                Binding="{Binding Step}"
                                                                IsReadOnly="True"
                                                                Width="50" />
                                            <DataGridTextColumn Header="名称"
                                                                Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="2*" />
                                            <DataGridTextColumn Header="动作编码"
                                                                Binding="{Binding ActionCode, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*" />
                                            <DataGridTextColumn Header="TCN 标签"
                                                                Binding="{Binding TcnLabel, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*" />
                                            <DataGridTextColumn Header="目标状态码"
                                                                Binding="{Binding ExpectedStateCode, UpdateSourceTrigger=PropertyChanged}"
                                                                Width="*" />
                                            <DataGridTemplateColumn Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Button Width="26" Height="26" Padding="0"
                                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                    Command="{Binding DataContext.MoveStepUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="上移">
                                                                <materialDesign:PackIcon Kind="ArrowUp" Width="14" Height="14" />
                                                            </Button>
                                                            <Button Width="26" Height="26" Padding="0" Margin="4,0,0,0"
                                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                    Command="{Binding DataContext.MoveStepDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="下移">
                                                                <materialDesign:PackIcon Kind="ArrowDown" Width="14" Height="14" />
                                                            </Button>
                                                            <Button Width="26" Height="26" Padding="0" Margin="4,0,0,0"
                                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                    Command="{Binding DataContext.RemoveStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    ToolTip="删除">
                                                                <materialDesign:PackIcon Kind="Close" Width="14" Height="14" />
                                                            </Button>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>

                                <Button Margin="0,10,0,0"
                                        MinWidth="100"
                                        Command="{Binding DataContext.AddStepCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Style="{StaticResource SecondaryDialogButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,6,0" />
                                        <TextBlock Text="添加步骤" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </materialDesign:Card>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="3"
                   Text="{Binding ErrorMessage}"
                   Foreground="#B00020"
                   Margin="0,8,0,0" />
    </Grid>
</Window>

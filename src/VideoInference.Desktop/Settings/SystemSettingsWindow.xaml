<Window x:Class="VideoInferenceDemo.SystemSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="系统设置"
        Height="620"
        Width="920"
        MinHeight="560"
        MinWidth="860"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="PrimaryDialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="SecondaryDialogButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="18,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#667085" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12.5" />
        </Style>

        <Style x:Key="AddIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="DeleteIconButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Background="#EEF3F8"
                BorderBrush="#D6E0EA"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10">
            <StackPanel>
                <TextBlock Text="系统设置"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#1F2937" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#667085"
                           Text="当前页面编辑指纹、Modbus IO 和灯光绑定等系统硬件配置。保存后会重新加载相关运行组件。"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <materialDesign:Card Grid.Row="1" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Data Retention"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                    </DockPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource FieldLabelStyle}"
                                   Text="Retention days" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding RetentionDaysText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2"
                                   Margin="12,0,0,0"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="1-3650" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="Auto cleanup" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  IsChecked="{Binding EnableAutoCleanup}" />
                    </Grid>

                    <Border Margin="0,0,0,12"
                            Height="1"
                            Background="#D6E0EA" />

                    <DockPanel Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="本机 ModbusTCP 服务端"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Foreground="#667085"
                                   Text="{Binding ModbusTcpServerStatusText}" />
                    </DockPanel>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Content="启用监听"
                                  IsChecked="{Binding ModbusTcpServerEnabled}" />
                        <TextBox Grid.Column="1"
                                 Margin="8,0,0,0"
                                 Text="{Binding ModbusTcpServerBindAddress, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2"
                                   Margin="8,0,0,0"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="监听地址" />
                        <TextBox Grid.Column="3"
                                 Margin="8,0,0,0"
                                 Text="{Binding ModbusTcpServerPortText, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="4"
                                   Margin="8,0,0,0"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Text="端口，默认 502" />
                    </Grid>

                    <DockPanel Margin="0,0,0,8">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   Text="保持寄存器监视"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Style="{StaticResource FieldLabelStyle}"
                                       Text="起始地址" />
                            <TextBox Width="90"
                                     Text="{Binding RegisterMonitorStartAddressText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Margin="8,0,0,0"
                                    Style="{StaticResource DeleteIconButtonStyle}"
                                    ToolTip="刷新"
                                    Command="{Binding RefreshRegisterMonitorCommand}">
                                <materialDesign:PackIcon Kind="Refresh" Width="14" Height="14" />
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding ModbusRegisterMonitorItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              IsReadOnly="True"
                              MinHeight="220"
                              MaxHeight="260">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="地址"
                                                Width="*"
                                                Binding="{Binding Address}" />
                            <DataGridTextColumn Header="值"
                                                Width="*"
                                                Binding="{Binding Value}" />
                            <DataGridTextColumn Header="HEX"
                                                Width="*"
                                                Binding="{Binding HexValue}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Margin="0,18,0,12"
                            Height="1"
                            Background="#D6E0EA" />

                    <DockPanel Margin="0,0,0,10" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="指纹模块"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                        <Button DockPanel.Dock="Left"
                                Margin="8,0,0,0"
                                Command="{Binding AddFingerprintModuleCommand}"
                                Style="{StaticResource AddIconButtonStyle}"
                                ToolTip="新增模块">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" />
                        </Button>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding FingerprintModules}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              MinHeight="160">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="启用"
                                                    Width="60"
                                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="名称"
                                                Width="120"
                                                Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="类型"
                                                Width="96"
                                                Binding="{Binding ConnectionKind, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="站号"
                                                Width="70"
                                                Binding="{Binding SlaveAddressText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="串口"
                                                Width="90"
                                                Binding="{Binding PortName, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="波特率"
                                                Width="90"
                                                Binding="{Binding BaudRateText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="校验"
                                                Width="80"
                                                Binding="{Binding Parity, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="TCP地址"
                                                Width="120"
                                                Binding="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="端口"
                                                Width="70"
                                                Binding="{Binding TcpPortText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="轮询(ms)"
                                                Width="90"
                                                Binding="{Binding PollIntervalMsText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DeleteIconButtonStyle}"
                                                ToolTip="删除"
                                                Command="{Binding DataContext.RemoveFingerprintModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Margin="0,18,0,12" Height="1" Background="#D6E0EA" />

                    <DockPanel Margin="0,0,0,10" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Modbus IO 模块"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                        <Button DockPanel.Dock="Left"
                                Margin="8,0,0,0"
                                Command="{Binding AddModbusModuleCommand}"
                                Style="{StaticResource AddIconButtonStyle}"
                                ToolTip="新增模块">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" />
                        </Button>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding ModbusModules}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              MinHeight="120">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="启用"
                                                    Width="60"
                                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="名称"
                                                Width="120"
                                                Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="地址"
                                                Width="130"
                                                Binding="{Binding Host, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="端口"
                                                Width="70"
                                                Binding="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="站号"
                                                Width="60"
                                                Binding="{Binding SlaveAddressText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="输出首地址"
                                                Width="90"
                                                Binding="{Binding OutputStartAddressText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="输入首地址"
                                                Width="90"
                                                Binding="{Binding InputStartAddressText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="轮询(ms)"
                                                Width="80"
                                                Binding="{Binding PollIntervalMsText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DeleteIconButtonStyle}"
                                                ToolTip="删除"
                                                Command="{Binding DataContext.RemoveModbusModuleCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Margin="0,18,0,12" Height="1" Background="#D6E0EA" />

                    <DockPanel Margin="0,0,0,10" LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="灯光绑定配置"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937" />
                        <Button DockPanel.Dock="Left"
                                Margin="8,0,0,0"
                                Command="{Binding AddLightBindingCommand}"
                                Style="{StaticResource AddIconButtonStyle}"
                                ToolTip="新增绑定">
                            <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" />
                        </Button>
                    </DockPanel>

                    <DataGrid ItemsSource="{Binding LightBindings}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              MinHeight="100">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="所属模块"
                                                Width="110"
                                                Binding="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="灯号"
                                                Width="60"
                                                Binding="{Binding LightNumber, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="红灯通道"
                                                Width="90"
                                                Binding="{Binding RedChannelText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="绿灯通道"
                                                Width="90"
                                                Binding="{Binding GreenChannelText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="蜂鸣器通道"
                                                Width="100"
                                                Binding="{Binding BuzzerChannelText, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridCheckBoxColumn Header="蜂鸣器启用"
                                                    Width="90"
                                                    Binding="{Binding BuzzerEnabled, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DeleteIconButtonStyle}"
                                                ToolTip="删除"
                                                Command="{Binding DataContext.RemoveLightBindingCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>

        <TextBlock Grid.Row="2"
                   Margin="0,8,0,0"
                   Foreground="#B00020"
                   Text="{Binding ErrorMessage}"
                   TextWrapping="Wrap" />

        <DockPanel Grid.Row="3" Margin="0,12,0,0" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="保存"
                        Click="OnSave"
                        Style="{StaticResource PrimaryDialogButtonStyle}" />
                <Button Content="取消"
                        Click="OnCancel"
                        Style="{StaticResource SecondaryDialogButtonStyle}"
                        Margin="0" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>

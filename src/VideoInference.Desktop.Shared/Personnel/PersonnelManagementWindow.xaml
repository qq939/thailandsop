<Window x:Class="VideoInferenceDemo.PersonnelManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="人员管理"
        Width="1120"
        Height="680"
        MinWidth="980"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <SolidColorBrush x:Key="PersonnelSelectedRowBrush" Color="#EAF4FF" />
        <SolidColorBrush x:Key="PersonnelSelectedRowBorderBrush" Color="#A8CDEB" />
        <SolidColorBrush x:Key="PersonnelSelectedTextBrush" Color="#17324D" />
        <SolidColorBrush x:Key="PersonnelHoverRowBrush" Color="#F6FAFE" />

        <Style x:Key="PersonnelTextBoxStyle"
               BasedOn="{StaticResource {x:Type TextBox}}"
               TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PersonnelComboBoxStyle"
               BasedOn="{StaticResource {x:Type ComboBox}}"
               TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="PersonnelGridTextBlockStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PersonnelGridTextBoxStyle"
               BasedOn="{StaticResource PersonnelTextBoxStyle}"
               TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="34" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="PersonnelGridCheckBoxStyle"
               BasedOn="{StaticResource {x:Type CheckBox}}"
               TargetType="{x:Type CheckBox}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PersonnelOutlinedButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PersonnelRaisedButtonStyle"
               BasedOn="{StaticResource MaterialDesignRaisedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PersonnelIconButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.Row="0" Padding="14,12" Margin="0,0,0,10" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1F3347"
                               Text="人员管理" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#667085"
                               Text="{Binding CurrentUserText}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#5E6B79"
                               Text="{Binding StatusText}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding StatusText}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button MinWidth="84"
                            Margin="0,0,10,0"
                            Command="{Binding RefreshCommand}"
                            Content="刷新"
                            Style="{StaticResource PersonnelOutlinedButtonStyle}" />
                    <Button MinWidth="84"
                            Command="{Binding AddPersonnelCommand}"
                            Content="新增"
                            Margin="0,0,10,0"
                            Style="{StaticResource PersonnelRaisedButtonStyle}" />
                    <Button MinWidth="84"
                            Command="{Binding SaveSelectedCommand}"
                            Content="保存"
                            Style="{StaticResource PersonnelRaisedButtonStyle}" />
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1">
            <materialDesign:Card Padding="10" Background="White">
                <DataGrid ItemsSource="{Binding Personnel}"
                          SelectedItem="{Binding SelectedPersonnel, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="MinHeight" Value="44" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PersonnelHoverRowBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PersonnelSelectedRowBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource PersonnelSelectedRowBorderBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource PersonnelSelectedTextBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="8,4" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderBrush" Value="#E2EAF2" />
                            <Setter Property="Foreground" Value="#1F2937" />
                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource PersonnelSelectedRowBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource PersonnelSelectedRowBorderBrush}" />
                                    <Setter Property="Foreground" Value="{StaticResource PersonnelSelectedTextBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="工号"
                                            Width="150"
                                            Binding="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}"
                                            ElementStyle="{StaticResource PersonnelGridTextBlockStyle}"
                                            EditingElementStyle="{StaticResource PersonnelGridTextBoxStyle}" />
                        <DataGridTextColumn Header="姓名"
                                            Width="140"
                                            Binding="{Binding EmployeeName, UpdateSourceTrigger=PropertyChanged}"
                                            ElementStyle="{StaticResource PersonnelGridTextBlockStyle}"
                                            EditingElementStyle="{StaticResource PersonnelGridTextBoxStyle}" />
                        <DataGridTextColumn Header="密码"
                                            Width="100"
                                            IsReadOnly="True"
                                            Binding="{Binding PasswordDisplayText}"
                                            ElementStyle="{StaticResource PersonnelGridTextBlockStyle}" />
                        <DataGridTextColumn Header="班组"
                                            Width="120"
                                            Binding="{Binding Team, UpdateSourceTrigger=PropertyChanged}"
                                            ElementStyle="{StaticResource PersonnelGridTextBlockStyle}"
                                            EditingElementStyle="{StaticResource PersonnelGridTextBoxStyle}" />
                        <DataGridTextColumn Header="指纹ID"
                                            Width="80"
                                            IsReadOnly="True"
                                            Binding="{Binding FingerprintIdText}"
                                            ElementStyle="{StaticResource PersonnelGridTextBlockStyle}" />
                        <DataGridCheckBoxColumn Header="启用"
                                                Width="70"
                                                Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}"
                                                ElementStyle="{StaticResource PersonnelGridCheckBoxStyle}"
                                                EditingElementStyle="{StaticResource PersonnelGridCheckBoxStyle}" />
                        <DataGridTemplateColumn Header="指纹" Width="230">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Width="132"
                                                  Style="{StaticResource PersonnelComboBoxStyle}"
                                                  ItemsSource="{Binding DataContext.AvailableModules, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding DataContext.SelectedFingerprintModule, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Name" />
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Content="录入"
                                                Command="{Binding DataContext.EnrollFingerprintCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PersonnelOutlinedButtonStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="备注"
                                            Width="*"
                                            Binding="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                            ElementStyle="{StaticResource PersonnelGridTextBlockStyle}"
                                            EditingElementStyle="{StaticResource PersonnelGridTextBoxStyle}" />
                        <DataGridTemplateColumn Header="操作" Width="64" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.ChangePasswordPersonnelCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PersonnelIconButtonStyle}"
                                                ToolTip="修改密码">
                                            <materialDesign:PackIcon Width="18"
                                                                     Height="18"
                                                                     Kind="Key" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <Border Visibility="{Binding IsEnrolling, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#CCF0F4F8"
                    CornerRadius="12">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="360"
                        Height="180"
                        Background="White"
                        BorderBrush="#D6E0EA"
                        BorderThickness="1"
                        CornerRadius="16"
                        Effect="{DynamicResource MaterialDesignShadowDepth3}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Fingerprint"
                                                 Width="48"
                                                 Height="48"
                                                 HorizontalAlignment="Center"
                                                 Foreground="#0F5A91" />
                        <TextBlock Margin="0,16,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2937"
                                   Text="指纹录入中"
                                   TextAlignment="Center" />
                        <TextBlock Margin="0,6,0,0"
                                   Padding="24,0"
                                   FontSize="13"
                                   Foreground="#667085"
                                   Text="{Binding StatusText}"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap" />
                        <ProgressBar Margin="32,16,32,0"
                                     Height="4"
                                     IsIndeterminate="True"
                                     Background="#E0E6ED"
                                     Foreground="#0F5A91" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>

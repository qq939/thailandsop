<Window x:Class="VideoInferenceDemo.PasswordChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="修改密码"
        Width="420"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="PasswordChangeBoxStyle"
               BasedOn="{StaticResource {x:Type PasswordBox}}"
               TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PasswordChangeOutlinedButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="PasswordChangeRaisedButtonStyle"
               BasedOn="{StaticResource MaterialDesignRaisedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#1F3347"
                       Text="修改密码" />
            <TextBlock x:Name="TargetUserTextBlock"
                       Margin="0,6,0,0"
                       Foreground="#5E6B79" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock FontWeight="SemiBold"
                       Foreground="#344054"
                       Text="新密码" />
            <PasswordBox x:Name="NewPasswordInput"
                         Grid.Row="1"
                         Margin="0,8,0,0"
                         KeyDown="OnPasswordKeyDown"
                         Style="{StaticResource PasswordChangeBoxStyle}" />
            <PasswordBox x:Name="ConfirmPasswordInput"
                         Grid.Row="2"
                         Margin="0,14,0,0"
                         KeyDown="OnPasswordKeyDown"
                         Style="{StaticResource PasswordChangeBoxStyle}"
                         materialDesign:HintAssist.Hint="再次输入新密码，留空表示空密码" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#B42318"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button MinWidth="82"
                        Margin="0,0,10,0"
                        Click="OnCancel"
                        Content="取消"
                        Style="{StaticResource PasswordChangeOutlinedButtonStyle}" />
                <Button MinWidth="82"
                        Click="OnConfirm"
                        Content="确认"
                        Style="{StaticResource PasswordChangeRaisedButtonStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>

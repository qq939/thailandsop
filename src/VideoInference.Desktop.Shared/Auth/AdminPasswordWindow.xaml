<Window x:Class="VideoInferenceDemo.AdminPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Admin 验证"
        Width="380"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F3F6FA"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style x:Key="AdminPasswordBoxStyle"
               BasedOn="{StaticResource {x:Type PasswordBox}}"
               TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="AdminOutlinedButtonStyle"
               BasedOn="{StaticResource MaterialDesignOutlinedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="AdminRaisedButtonStyle"
               BasedOn="{StaticResource MaterialDesignRaisedButton}"
               TargetType="{x:Type Button}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#1F3347" Text="Admin 密码验证" />
            <TextBlock Margin="0,6,0,0" Foreground="#5E6B79" Text="管理人员需要输入 Admin 密码。" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,20,0,0">
            <PasswordBox x:Name="PasswordInput"
                         KeyDown="OnPasswordKeyDown"
                         Style="{StaticResource AdminPasswordBoxStyle}" />
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,10,0,0"
                       Foreground="#B42318"
                       TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button MinWidth="80"
                    Margin="0,0,10,0"
                    Click="OnCancel"
                    Content="取消"
                    Style="{StaticResource AdminOutlinedButtonStyle}" />
            <Button MinWidth="80"
                    Click="OnConfirm"
                    Content="确认"
                    Style="{StaticResource AdminRaisedButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
